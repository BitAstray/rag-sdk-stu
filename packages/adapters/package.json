{
  "name": "@rag-sdk/adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./langchain": {
      "types": "./src/langchain/index.ts",
      "import": "./src/langchain/index.ts"
    },
    "./chroma": {
      "types": "./src/chroma/index.ts",
      "import": "./src/chroma/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm --filter @rag-sdk/core --filter @rag-sdk/indexing build",
    "test": "pnpm run build && vitest run",
    "test:watch": "vitest watch",
    "demo": "pnpm run build && tsx demo/langchain-pipeline.ts"
  },
  "dependencies": {
    "@rag-sdk/core": "workspace:*",
    "@rag-sdk/indexing": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
